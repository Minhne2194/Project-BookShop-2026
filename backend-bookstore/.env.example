# =============================================================================
# ENVIRONMENT VARIABLES — Copy this file to .env and fill in your values
# =============================================================================

# DATABASE CONFIGURATION
DATABASE_URL="postgresql://user:password@localhost:5433/bookstore_db?schema=public"

# JWT CONFIGURATION
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# REDIS CONFIGURATION
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# MOMO PAYMENT (SANDBOX)
MOMO_PARTNER_CODE="your-momo-partner-code"
MOMO_ACCESS_KEY="your-momo-access-key"
MOMO_SECRET_KEY="your-momo-secret-key"
MOMO_RETURN_URL="http://localhost:5173/payment/result"
MOMO_NOTIFY_URL="https://your-ngrok-url.ngrok-free.dev/payment/momo/callback"

# VNPAY PAYMENT (SANDBOX)
VNPAY_TMN_CODE="your-vnpay-tmn-code"
VNPAY_HASH_SECRET="your-vnpay-hash-secret"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:5173/payment/result"
VNPAY_NOTIFY_URL="https://your-ngrok-url.ngrok-free.dev/payment/vnpay/callback"

# APPLICATION CONFIGURATION
PORT=3000
FRONTEND_URL="http://localhost:5173"
PAYMENT_RESULT_URL="http://localhost:5173/payment/result"

# PAYOS
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
